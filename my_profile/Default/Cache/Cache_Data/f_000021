    /**
     * 保留函数只是为了兼容以前代码
     * 这里是异步请求格式,而且只用来处理下发cli命令
     * 重构该函数，11.x平台跟10.x平台以前的接口有变化，这里采用jquery ajax请求
     * 有汉字的返回结果需特殊处理，交由模块自己处理，此处返回原始数据
     * @param {Array|String} strCLIMode 下发命令模式,如果是数组拼接成model1#model2字符串
     * @param {String} strCLICommand 下发具体命令
     * @param {Function} func 异步执行函数
     * @param {String|Object} answer 应答字符串，只要用于一些需要应答型的命令，比如重启可以直接跟上应答yes，为对象时传递配置信息，{answer:'应答字符串',notdelay:true}
     * @returns {Array|Boolean} 错误返回false,未认证返回null,成功返回解析过的数组
     */
    asy_request : function(strCLIMode, strCLICommand, func, answer, option) {
        var self = this;
        if (!option) {
            option = {};
        }
        if ( typeof func !== "function") {
            answer = func;
            func = function () {
            };
        }
        if (answer && typeof answer === "object") {
            if (answer.answer) {
                var tmp = answer.answer;
                delete answer.answer;
            }
            $.extend(option, answer);
        }
        if (tmp)
            answer = tmp;
        if (typeof answer === "object")
            answer = null;
        if (func === undefined)
            func = function () {
            };
        option.success = function(data) {
            if(!!option&&!!option.batch){
                func(self.continueSplit(data,option));
            }else{
                //374405 Running this command may take some time, please wait.
                var returnmsg = data;
                if(!!returnmsg){
                    if(returnmsg.indexOf("Running this command may take some time, please wait.\r\n")!=-1){
                        returnmsg = returnmsg.replace("Running this command may take some time, please wait.\r\n","");
                    }else{
                        returnmsg = returnmsg.replace("Running this command may take some time, please wait.","");
                    }  
                }
                func(self.parseResult(returnmsg, option));
            }
        };
        option.async = true;
        option.charset = "gbk";
        if(!!option&&!!option.charset){
            option.charset = option.charset;
        }else{
            option.charset = "gbk";
        }
        this.request(strCLIMode, strCLICommand, answer, option);
        return false;
    },
    /**
     * 重构该函数，11.x平台跟10.x平台以前的接口有变化，这里采用jquery ajax请求
     * 该函数只用于下发cli命名，登录、上传、下载不再使用，因为不同机制返回的数据格式有区别，无法统一
     * 中文request,有汉字的返回结果需特殊处理，交由模块自己处理，此处返回原始数据
     * @param {Array|String} strCLIMode 下发命令模式,如果是数组拼接成model1#model2字符串
     * @param {String} strCLICommand 下发具体命令
     * @param {String} answer 应答字符串，只要用于一些需要应答型的命令
     * @param {Obeject} option 配置对象，由于默认情况下是处理cli请求的，当有option时可灵活请求其他数据
     *                   option{
     *                      async: false 默认为同步加载
     *                      htmlspecialchars: false 默认为不需要转义
     *                      success: 请求成功处理函数，默认使用parseResult处理数据并返回结果
     *                      error:请求失败请求处理函数，默认弹出网络连接失败警告
     *                      statusfn:状态码，处理函数，默认弹出警告，未授权跳回首页
     *                      notdelay:true   登录超时不延迟
     *                      reload:true 命令下发完是否接着重启
                            charset : gbk/utf-8 默认为gbk，各模块有特殊需求可传参utf-8
                            isjson : true返回json，false返回数组 默认为false
                            refreshtime : 手动填充lasttime登录时间，传参的单位为秒
                            batch : true为支持连续加载show命令，支持exec模式，分隔符为END?YES
     *                   }
     * @returns {Array|Boolean} 错误返回false,无错误时返回解析的数组，无任何数据就是空数组
     */
    request: function (strCLIMode, strCLICommand, answer, option) {
        var that = this;
        if($.cookie("accountType") == "read" && strCLIMode == "config"){
            window.top.location.href = '/onlyread/onlyread.html';
            return false;
        }
        if (answer && typeof answer === "object")
            option = answer;
        var ajaxData = {}, isOption = typeof option === "object", returnmsg = false;
        var fn = isOption && typeof option.success === 'function' ? option.success : null;
        var statusFn = isOption && typeof option.statusfn === 'function' ? option.statusfn : null;
        var errorfn = isOption && typeof option.error === 'function' ? option.error : null;
        var ajaxOption = {
            //dataType: 'json',
            //timeout: that.ajaxtimeout,
            type: 'post'
        };
        if (!strCLICommand)
            return []; //没有传递命令
        if (!strCLIMode)
            strCLIMode = 'exec';
        //过滤debug support
        var validateCmd = $.trim(strCLICommand);
        if(/^debug\s+support[\s\S]*/.test(validateCmd)){
            return [];
        }
        //校验XXS
        if(strCLIMode == "config"){
            var cmdFlag = Util.xxsValidate(strCLICommand);
            if(!cmdFlag){
                return;
            }
        }
        if(!!option&&!!option.batch){
            ajaxOption.url = "/cli.php?a=continushow";
        }else{
            ajaxOption.url = "/newcli.php";
        }
        ajaxData.mode_url = strCLIMode;
        ajaxData.command = $.trim(strCLICommand);
        ajaxData.charset = "gbk";
        if(!!option&&!!option.charset){
            ajaxData.charset = option.charset;
        }else{
            ajaxData.charset = "gbk";
        }
        if (!!answer && typeof answer !== "object")
            ajaxData.answer = answer;
        if (isOption && option.notdelay !== undefined)
            ajaxData.notdelay = option.notdelay;
        if (isOption && option.reload !== undefined)
            ajaxData.reload = option.reload;
        if (isOption && option.refreshtime !== undefined)
            ajaxData.refreshtime = option.refreshtime;
        if (isOption && option.htmlspecialchars === true)
            ajaxData.htmlspecialchars = true;
        ajaxOption.data = ajaxData;
        ajaxOption.async = (isOption && option.async !== undefined) ? option.async : false;
        ajaxOption.success = function (data) {
            return returnmsg = that._success(data, fn, statusFn);
        };
        ajaxOption.error = function (XMLHttpRequest, textStatus, errorThrown) {
            return returnmsg = that._error(XMLHttpRequest, textStatus, errorThrown, errorfn);
        };
        $.ajax(ajaxOption);
        if(!!option&&!!option.batch&&!!returnmsg){
            var continuArr = that.continueSplit(returnmsg,option);
            return continuArr;//返回是数组，几条cli为数组的长度
        }else{
            //374405 Running this command may take some time, please wait.
            if(!!returnmsg){
                if(returnmsg.indexOf("Running this command may take some time, please wait.\r\n")!=-1){
                    returnmsg = returnmsg.replace("Running this command may take some time, please wait.\r\n","");
                }else{
                    returnmsg = returnmsg.replace("Running this command may take some time, please wait.","");
                }  
            }
            return this.parseResult(returnmsg, option);
        }
    },
