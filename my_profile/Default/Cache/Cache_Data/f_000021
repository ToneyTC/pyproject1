    /**
     * 访问非登录页时，需要检查用户是否登录
     **/
    checkAccess: function () {
        var that = this;
        var page = that.pathname.substring(that.pathname.lastIndexOf("\/") + 1);
        //修复漏洞http://www.wooyun.org/bugs/wooyun-2014-082472
        if (this.pathname !== "/index.htm" && this.pathname !== "/" && this.pathname !== "/main.htm" && window.opener && window.opener !== window) {  //弹窗
            try{
                if (window.opener.top.__cache == undefined) {
                    window.opener = null;
                    window.close();
                }
            }catch(e){};
        } else if(!window.dialogArguments){  //非弹窗
            if ( page !== "app_route.htm" && page !== "master.htm" && page !== "vpn_export.htm" && page !== "onlyread.html" && page !== "main.htm" && page !== "set_k.htm" && page !== "set_passw.htm" && page !== "packetCapture.html" && page !== "flow_user_detail.htm" && that.pathname.indexOf("/cache.htm") === -1 && that.pathname !== "/index.htm" && that.pathname !== "/" && window.top && window.top.__cache == undefined) {
                top.window.location = "/";
            }
        }
        if (this.pathname !== "/index.htm" && this.pathname !== "/") {
            var islogin = window.top && window.top.CLI ? window.top.CLI._islogin : that._islogin;
            if (islogin !== true) {
                $.ajax({
                    type: "post",
                    url: "/cli.php?a=checklogin",
                    async: true,
                    success: function (data) {
                        that._success(data, function () {
                            window.top && window.top.CLI ? window.top.CLI._islogin = true : that._islogin = true;
                        });
                    },
                    error: function (XMLHttpRequest, textStatus, errorThrown) {
                        that._error(XMLHttpRequest, textStatus, errorThrown);
                    }
                });
            }
        }
    },
