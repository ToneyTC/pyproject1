    /**
     * 移植防火墙
     * @description 从CLI中获取的数据,返回数组
     * @param {String}
     *            strCLICommand 配置的命令串
     * @param {String}
     *            isAnswer
     * @return {Boolean} 返回true or false
     */
    getCliData: function (strCLICommand, key) {
        var result = this.getCliConfig(strCLICommand, null);
        if (!result || result == -1 || result == -1) {
            return [];
        }
        var beginIndex = result.indexOf(key);
        var data = [];
        if (beginIndex == -1) {
            return [];
        }
        var aResult = result.split(key);
        for (var i = 0; i < aResult.length; i++) {
            var temp = aResult[i];
            if (!temp || temp.trim() == "" || temp == "\n" || temp == "\r\n") {
                continue;
            }
            data.push(key + temp);
        }
        return data;

    },
