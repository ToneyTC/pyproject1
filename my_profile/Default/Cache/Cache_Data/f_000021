    /**
     * ajax请求成功后返回数据的处理
     * @param {object|string} data 数据对象或json字符串
     * @param {FUnction} fn 异步处理函数
     */
    _success: function (data, fn, statusFn) {
        if (data === null)
            return false;
        //        if (typeof data === "string")
        //            data = $.parseJSON(data);
        if (!data.hasOwnProperty("status") || data.status === 1 || data.status === true) {//数据没有错误
            data = data.data !== undefined ? data.data : data;
            if (fn && typeof fn === "function") {
                fn(data);
                return true;
            } else {
                return data;
            }
        }
        if (statusFn && typeof statusFn === "function") {   //状态码处理函数
            statusFn(data.status);
            return false;
        } else {
            if (data.status === 0 || data.status === false || data.status === 4) {  //未登录或者登录超时
                if (window.opener && window.opener !== window) {
                    window.opener = null;
                    window.close();
                } else if (this.pathname !== "/index.htm" && this.pathname !== "/") {
                    top.window.location = "/loginout.php" + (data.status === 4 ? "?timeout=1" : "");
                }
                return false;
            }
            if (data.status > 0) { //请求失败
                this._doCheck(data.status, data.msg);
                return  false;
            }
        }
    },
    /**
     * ajax请求过程中发生错误
     * @param {object} XMLHttpRequest XMLHttpRequest对象
     * @param {string} textStatus 状态值
     * @param {object} errorThrown 异常抛出
     * @param {Function} fn 错误执行函数
     * @returns {Boolean} false
     */
    _error: function (XMLHttpRequest, textStatus, errorThrown, fn) {
        if (fn && typeof fn === 'function') {
            fn(XMLHttpRequest, textStatus, errorThrown);
        } else {
            var network_alert_time = window.top && window.top.CLI ? window.top.CLI.network_alert_time : this.network_alert_time;
            if (network_alert_time === undefined)
                network_alert_time = 0;
            var date = new Date();
            var nowtime = date.getTime();
            if ((textStatus === 'timeout' || XMLHttpRequest.status === 404) && (nowtime - parseInt(network_alert_time)) > this.alertintval) {
                window.top && window.top.CLI ? window.top.CLI.network_alert_time = nowtime : this.network_alert_time = nowtime;
                //this.isZh() ? alert("请求出错，请检查你的网络！") : alert("Request error, pelease cheak your network!");//434211 升级过程出错问题
            }
        }
        return false;
    },
    /*
     * 解析ajax返回的数据为数组
     * @param {String} strResult ajax返回的数据
     * @returns {Array}返回分割后的二维数组
     */
    continueSplit :  function(returnmsg,option){
        var continuStr = returnmsg.split("END?YES"),continuArr=[];
        for (var i = 0; i < continuStr.length-1; i++) {
            continuArr.push(this.parseResult(continuStr[i], option));
        }
        return continuArr;//返回是数组，几条cli为数组的长度
    },
    /*
     * 解析ajax返回的数据为数组
     * @param {String} strResult ajax返回的数据
     * @returns {Array}{Object}返回分割后的数组或对象
     */
    parseResult : function(strResult, options) {
        if (options && options.returnType == "String") {
            if (!strResult) {
                return "";
            }
            return (strResult).replace(/\r*\n/g, "\n");

        }
        // 11.x平台以\n 做分割
        if (!strResult || !$.trim(strResult.replace(/(\r\n){1,}/g, ""))){
            return [""];
        }
        if(options&&options.isTrim){
            strResult=$.trim(strResult);
        }
        //
        if(options&&options.isjson){
            try{
                strResult = eval("(" + strResult + ")");
            }catch(err) {
                strResult = "";
        　　}
        }else{
            if(!!options&&!!options.batch){
                var data = (strResult).replace(/\r*\n/g, "<?>").split("<?>");
                strResult = [];//重置数组，过滤空字符串
                for (var i = 0; i < data.length; i++) {
                    if(!!data[i]){
                        strResult.push(data[i]);
                    }
                }
            }else{
                strResult = (strResult).replace(/\r*\n/g, "<?>\r\n").split("<?>");
            }
            if ($.trim(strResult.join("")) == "") {
                strResult = [""];
            }
        }
        //console.log(strResult);

        return strResult;
    },
    /**
     * @description ajax post请求数据，主要用于请求php数据
     * @param {string} url
     * @param {object} params
     * @param {function} fn 存在该参数时则为异步请求
     * @returns {object} 同步请求时返回json数据，异步时无返回
     */
    post: function (url, params, fn) {
        var that = this;
        if (!params)
            params = {};
        if (typeof params === "function") {
            fn = params;
            params = {};
        }
        var content = false;
        $.ajax({
            type: "post",
            url: url,
            data: params,
            //timeout: that.ajaxtimeout,
            async: !!fn && typeof fn === "function",
            success: function (data) {
                return content = that._success(data, fn && typeof fn === "function" ? fn : null);
            },
            error: function (XMLHttpRequest, textStatus, errorThrown) {
                return content = that._error(XMLHttpRequest, textStatus, errorThrown);
            }
        });
        return content;
    },
