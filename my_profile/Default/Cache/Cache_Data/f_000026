function Login() {
}

Login.prototype = {
    loginWeb :function() {
        var that = this;
        var username = $('#username');
        var password = $('#password');
        var usernameValue = $.trim(username.val());
        var passwordValue = $.trim(password.val());
        if(usernameValue === ""){
            that.setTip(Resource["eg.login.pleaseEnterUsernameTip"],"username");
            return false;
        }
        if(passwordValue === ""){
            that.setTip(Resource["eg.login.pleaseEnterPassTip"],"password");
            return false;
        }
        $("#login").attr("disabled",true);
        $("#login").text(Resource["eg.login.isLogining"]);
        var encrypt = new JSEncrypt.JSEncrypt();
        encrypt.setPublicKey(that.pubLicKey);
        that.encPassword = encrypt.encrypt(passwordValue);
        $.ajax({
            dataType: 'json',
            type: 'post',
            async: false,
            url: "/login.php",
            data: {
                "username":GibberishAES.enc(usernameValue, 'RjYkhwzx\$2018!').replace(/\s+/g, ''),
                "password":that.encPassword
            },
            success: function (data) {
                $.cookie('isRedirect', "true");
                if (data.status === 1 || data.status === true) {
                    if(!data.result){//底层返回null，当初code == 6处理
                        that.cycleLogin(usernameValue,passwordValue);
                    }
                    if (data.result.code !== undefined && (data.result.code == 0 || data.result.code == 3)) {//登录成功
                        if(data.result.code == 3){
                            alert(Resource["eg.login.passwordTooLow"]);
                        };
                        if(data.result.privilege>13){
                            that.accountType = "write";
                        }else{
                            that.accountType = "read";
                        }
                        that.authenType = data.result.authen;
                        that.loginValidSucc(usernameValue,passwordValue);
                    } else if (data.result.code == 6){//等待结果, 用另一个命令查询结果.底层旧返回一个字符6
                        that.cycleLogin(usernameValue,passwordValue);
                    }else if (data.result.code == 4 || data.result.code == 2 || data.result.code == 1){//登录失败
                        if(!!data.result["lock-time-left"]){
                            $("#loginErrorTip").html(Resource["eg.login.loginfailExceeded"]+data.result["lock-time-left"]+Resource["eg.login.trytoLoginAgain"]);
                        }else if(!!data.result["error-cnt-left"]){
                            $("#loginErrorTip").html(Resource["eg.login.loginErrorHaveleft"]+data.result["error-cnt-left"]+Resource["eg.login.trialChanceLogin"]);
                        } else{
                            $("#loginErrorTip").html(Resource["eg.login.loginFail"]);
                        }
                        $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                    }else if (data.result.code == 5){
                        $("#loginErrorTip").html(Resource["eg.login.loginUserLimit"]);
                        $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                    }else{
                        $("#loginErrorTip").html(Resource["eg.login.loginFail"]);
                        $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                    }
                } else if (data.status === 5) {//用户名或密码不能为空
                    that.setTip(Resource["eg.login.usernameOrPassNull"],"username");
                    $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                }  else if (data.status === 7) {//账号密码不能同时为manager或者guest
                    that.setTip(Resource["eg.login.contactAdministratorChange"],"username");
                    $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                } else {//其他错误
                    that.setTip(Resource["eg.login.loginFailerror"]);
                    $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                }
            },
            error: function () {
                that.setTip(Resource["eg.login.loginfailNetworkInterruption"],"username");
                $('#login').html(Resource["eg.login.loginText"])[0].disabled = false;
            }
        });
        return false;
    },
    showCheckDialog:function() {
        var that = this;
        that.noNeedCheck = false;
        if(!that.initCheckDb) {
            that.initCheckDb = rui.Dialog.open({
                content:Resource["eg.login.systemIsloading"],
                title: Resource["eg.login.loginText"],
                width:450,
                height:130,
                allowClose:false,
                show: true,
                buttons: [
                    {
                        type:"ok",
                        text:Resource["eg.login.detectLoadingProgress"],
                        onclick: function (item, dialog) {
                            that.initCheckDb.hide();
                            that.isChecking = true;
                            that._starLoader(Resource["eg.login.systemLoading10"]);
                            window.setTimeout(function(){
                                that.intervalidCheckDb = setInterval(function(){
                                    that.checkStatus();
                                }, 5000); //11.x需要重新授权
                            }, 1000);
                        }
                    },
                    {
                        type:"cancel",
                        text:Resource["eg.login.directLogin"],
                        onclick: function (item, dialog) {
                            that.initCheckDb.hide();
                            that.noNeedCheck = true;
                            that.loginWeb();
                        }
                    }
                ],
                closeWindowEvent: function(){

                }
            });
        } else {
            that.initCheckDb.show();
        }
    },
    checkStatus: function () {
        var that = this;
        if(that.isChecking) {
            that.checkNum += 1;
            var num = parseInt(Math.round(that.checkNum / 70 * 10000) / 100);
            num = num + 10;
            if(num>100){
                num = 100;
            }
            that._starLoader(Resource["eg.login.featureLibraryIsloading"] + num + "%");
        }
        if(that.isChecking && that.checkNum>71){
            alert(Resource["eg.login.detectionCompleted"]);
            self.noNeedCheck = true;
            that.loader && that.loader.loadComplete();
            window.clearInterval(that.intervalidCheckDb);
            return false;
        }
        var ajaxTimeOut = $.ajax({
            type: 'post',
            url: "/login.php?a=getIdversion",
            timeout: 2000,
            success: function (data){
                if(data.data.toString().indexOf("Version:20")>-1){
                    if(that.isChecking){
                        that._starLoader(Resource["eg.login.systemLoadingCompleted"]);
                        setTimeout(function(){
                            that.loader && that.loader.loadComplete();
                            window.clearInterval(that.intervalidCheckDb);
                            alert(Resource["eg.login.pleaseLoginAgain"]);
                        },1000)
                    }else{
                        that.loginWeb();
                    }
                }else{
                    if(!that.isChecking){
                        that.showCheckDialog();
                    }
                }
            },
            complete : function(XMLHttpRequest,status){ //请求完成后最终执行参数
                if(status=='timeout'){//超时,status还有success,error等值的情况
                    if(!that.isChecking){
                        that.showCheckDialog();
                    }
                    ajaxTimeOut.abort();
                }
            }
        })
    },
    cycleLogin:function (usernameValue,passwordValue) {
        var that = this;
        var pcIp = that.pcIp;
        CLI.post("/login.php?a=cycleLogin",{
            "username":GibberishAES.enc(usernameValue, 'RjYkhwzx\$2018!').replace(/\s+/g, ''),
            "password":that.encPassword,
            "hostip":pcIp
        },function (res){
            if(!!res){
                var data = $.parseJSON(res);
                if(data.msg == "success"){
                    if(!!data.privilege && data.privilege>13){
                        that.accountType = "write";
                    }else{
                        that.accountType = "read";
                    }
                    that.authenType = data.authen;
                    that.loginValidSucc(usernameValue,passwordValue);
                }else if(data.msg == "wait"){
                    setTimeout(function () {
                        that.cycleLogin(usernameValue,passwordValue);
                    },1000)
                }else if(data.msg == "locked"){
                    alert(Resource["eg.login.accountIslocked"]);
                    $("#loginErrorTip").html(Resource["eg.login.loginFail"]);
                    $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                }else if(data.msg == "limit error"){
                    alert(Resource["eg.login.loginUserLimit"]);
                    $("#loginErrorTip").html(Resource["eg.login.loginFail"]);
                    $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                }else if(data.msg == "aaa reject"){
                    alert(Resource["eg.login.accountPassError"]);
                    $("#loginErrorTip").html(Resource["eg.login.loginFail"]);
                    $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                }else if(data.msg == "aaa timeout"){
                    alert(Resource["eg.login.authServerTimedout"]);
                    $("#loginErrorTip").html(Resource["eg.login.loginFail"]);
                    $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                }else{
                    alert(Resource["eg.login.loginFail"]);
                    $("#loginErrorTip").html(Resource["eg.login.loginFail"]);
                    $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
                }
            }else{
                alert(Resource["eg.login.loginFail"]);
                $("#loginErrorTip").html(Resource["eg.login.loginFail"]);
                $('#login').html(Resource["eg.login.loginBtn"])[0].disabled = false;
            }
        });
    },
    loginValidSucc:function (usernameValue,passwordValue) {
        var that = this;
        $('#login')[0].disabled = false;
        var mode = window.top.GATEWAY_CUSTOM.HARD_MODE_WEBLOG;
        CLI.log(usernameValue + Resource["eg.login.userLoginText"], true, mode);
        //清楚框架页tab记忆功能
        $.removeCookie('module');
        $.removeCookie('threeModule');
        if(usernameValue== "admin" && passwordValue== "admin") {
            CLI.post( "/reset.php?a=getFile",function(data){
                var isTag = false;
                for (var i = 0 ;i < data.length;i++) {
                    if (data[i] && data[i].indexOf(".config.text.bak") != -1) {
                        that.showResetFileDialog(passwordValue);
                        var isTag = true;
                        break;
                    }
                }
                if (!isTag) {
                    that.loginSuccess(passwordValue);
                }
            });
        } else {
            that.loginSuccess(passwordValue);
        }
    },
