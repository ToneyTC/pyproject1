    loginSuccess : function(passwordValue){
        //清楚框架页下tab页当前tab id
        var self = this;
        //判断浏览器语言与设备是否一致
        /*if(window.top.GATEWAY_CUSTOM.supportMoreLan) {
            var flag = self.alertLanTip();
            if(flag){
                return
            }
        }*/
        $.cookie("authenType",self.authenType);
        if(self.accountType == "read"){
            //判断是不是只读账号
            $.cookie("accountType","read");
            window.open("onlyread/onlyread.html", "_self");
            return false;
        }else{
            $.cookie("accountType","write");
        }
        if(self.authenType == "aaa"){
            //判断是不是服务器账号
            window.open(mainPage, "_self");
            return false;
        }
        var yOrN = (passwordValue == "admin") ? '' : '?defPassword=n';
        if(window.top.GATEWAY_CUSTOM.quick_set){
            if (!self.isSysmode&&self.isNoConfig == "0") {
                mainPage = 'quick_set_pi/set_k.htm' + yOrN;
            } else if (!self.isSysmode&&passwordValue == "admin") {
                mainPage = 'system_pi/set_passw.htm';
            } else if (!!self.isSysmode&&passwordValue == "admin") {
                mainPage = 'system_pi/set_passw.htm';
            }
        } else {
            if (passwordValue == "admin") {
                if(self.authenType != "aaa"){
                    mainPage = 'system_pi/set_passw.htm';
                }
            } else if (self.isNoConfig == "0") {
                mainPage = 'quick_set_pi/set_k.htm';
            }
        }
        // -P设备移动端通过手机在登录页登录后总是跳转到第二次快速配置
        if(!!window.top.GATEWAY_CUSTOM.commonwifi && !self.isPC()){
            mainPage = 'quick_set_pi/set_k.htm?type=local';
        }
        // BUGID：496527 MACC全网配置点击跳转按钮后，需要重新输入密码，输入密码后应该跳转到MACC全网配置-接口配置页面继续进行配置；
		var queryMap = Util.getQueryPars();
		if(queryMap["type"] == 'macc'){
            mainPage = 'quick_set_pi/set_k.htm?type=macc';
        }
        /*if(window.top.GATEWAY_CUSTOM.IS_MACC_DEMO){
            mainPage = 'quick_set_pi/set_k.htm?type=mode';
        }*/
        var isFormApp=$.cookie("rg_app_quickset_cookie")?true:false;
        if(isFormApp){
            mainPage = 'quick_set_pi/set_k.htm';
        }
        $.cookie('showPatchDialog',true);
        //易用性修订   web-quickset为0，密码不是默认密码admin
        if(self.isNoConfig == "0" && passwordValue != "admin"){
            mainPage = 'quick_set_pi/set_k.htm?type=local';
        }
        //NBR睿易一体化
        if(window.top.GATEWAY_CUSTOM.PROD_MODE == "NBR"){
            var sweep_qrcode_data = request("exec", "show macc qr-code-set");
            if($.trim(sweep_qrcode_data[0]) == "0"){
                mainPage = 'quick_set_pi/set_k.htm?type=local';
            }
            if((self.isNoConfig == "0" && passwordValue == "admin") || queryMap["type"] == 'masterQuickset'){
                mainPage = 'quick_set_pi/master.htm';
            }
        }
        window.open(mainPage, "_self");
