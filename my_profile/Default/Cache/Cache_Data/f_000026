    alertLanTip: function(){
        var that = this;
        //判断浏览器语言与设备是否一致
        var o = window.navigator;
        var lan = o.userLangeage || o.language || o.systemLanguage || o.browserLanguage;
        var browserLanIsZh = lan == 'zh-cn' || lan == 'zh-CN';
        var deviceLanIsZh = Util.isZh();
        if(browserLanIsZh && !deviceLanIsZh){
            //切换成中文
            if(confirm("当前浏览器语言是中文，是否将设备语言切换成中文，切换后会重启设备")){
                CLI.log(Resource["eg.pub.log.lanChangeToChinese"]);
                this.changeLan("zh");
                return true;
            }else{
                return false
            }
        }
        if(!browserLanIsZh && deviceLanIsZh){
            //切换成英文
            if(confirm("The current browser language is English. Do you want to switch the device language to English? After switching, the device will be restarted")){
                CLI.log(Resource["eg.pub.log.lanChangeToEnglish"]);
                this.changeLan("en");
                return true;
            }else{
                return false
            }
        }
    },
    changeLan: function(lan){
        var that = this;
        that._starLoader(Resource["eg.login.isRestartWait"]);
        setTimeout(function(){
            CLI.post( "/patch.php?a=changeLan",{"lan":lan},function(data){});
            window.setTimeout(function(){
                that.intervalid = setInterval(function(){
                    that.update_dd();
                }, 1000);
            }, 2000)
        }, 200);
    },
    isPC: function(){
        var userAgentInfo = navigator.userAgent;
        var Agents = new Array("Android", "iPhone", "SymbianOS", "Windows Phone", "iPad", "iPod");
        var flag = true;
        for (var v = 0; v < Agents.length; v++) {
            if (userAgentInfo.indexOf(Agents[v]) > 0) { flag = false; break; }
        }
        return flag;
    }
